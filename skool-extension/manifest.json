{
  "manifest_version": 3,
  "name": "Universal Video Downloader",
  "version": "2.0.0",
  "description": "Download videos from Skool, YouTube, Vimeo, Wistia, Brightcove and 1000+ other sites",
  "permissions": ["storage", "downloads", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Video Downloader"
  }
}
